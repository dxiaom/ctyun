#!/bin/bash

PYTHON_CMD="__PYTHON_CMD__"
CONFIG_DIR="__CONFIG_DIR__"
SCRIPT_PATH="$CONFIG_DIR/ctyun_keepalive.py"
CONFIG_FILE="$CONFIG_DIR/config.json"
PID_FILE="$CONFIG_DIR/ctyun.pid"
LOG_FILE="$CONFIG_DIR/ctyun.log"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

show_help() {
    echo -e "${BLUE}天翼云桌面保活工具${NC}"
    echo ""
    echo "用法: ctyun <命令>"
    echo ""
    echo "命令:"
    echo "  config    配置账号密码"
    echo "  start     启动保活服务"
    echo "  stop      停止保活服务"
    echo "  restart   重启保活服务"
    echo "  status    查看服务状态"
    echo "  logs      查看日志 (支持 -f 实时查看)"
    echo "  uninstall 卸载服务"
    echo "  help      显示帮助信息"
    echo ""
}

check_running() {
    if [ -f "$PID_FILE" ]; then
        PID=$(cat "$PID_FILE")
        if ps -p "$PID" > /dev/null 2>&1; then
            return 0
        else
            rm -f "$PID_FILE"
        fi
    fi
    return 1
}

get_pid() {
    if [ -f "$PID_FILE" ]; then
        cat "$PID_FILE"
    fi
}

do_config() {
    log_info "配置天翼云账号"
    
    if [ ! -d "$CONFIG_DIR" ]; then
        mkdir -p "$CONFIG_DIR"
    fi
    
    if [ -f "$CONFIG_FILE" ]; then
        read -p "配置文件已存在，是否重新配置？(y/n): " confirm
        if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
            log_info "取消配置"
            return
        fi
        rm -f "$CONFIG_FILE"
    fi
    
    log_info "请输入账号信息："
    $PYTHON_CMD "$SCRIPT_PATH"
}

do_start() {
    if check_running; then
        log_warn "服务已在运行中 (PID: $(get_pid))"
        return 1
    fi
    
    if [ ! -f "$CONFIG_FILE" ]; then
        log_error "未找到配置文件，请先运行 'ctyun config' 进行配置"
        return 1
    fi
    
    log_info "正在启动保活服务..."
    
    nohup $PYTHON_CMD "$SCRIPT_PATH" >> "$LOG_FILE" 2>&1 &
    PID=$!
    echo $PID > "$PID_FILE"
    
    sleep 2
    
    if ps -p "$PID" > /dev/null 2>&1; then
        log_info "服务启动成功 (PID: $PID)"
    else
        log_error "服务启动失败，请查看日志: $LOG_FILE"
        rm -f "$PID_FILE"
        return 1
    fi
}

do_stop() {
    if ! check_running; then
        log_warn "服务未运行"
        return 1
    fi
    
    PID=$(get_pid)
    log_info "正在停止服务 (PID: $PID)..."
    
    kill "$PID" 2>/dev/null
    
    for i in {1..10}; do
        if ! ps -p "$PID" > /dev/null 2>&1; then
            break
        fi
        sleep 1
    done
    
    if ps -p "$PID" > /dev/null 2>&1; then
        log_warn "强制终止服务..."
        kill -9 "$PID" 2>/dev/null
    fi
    
    rm -f "$PID_FILE"
    log_info "服务已停止"
}

do_restart() {
    log_info "正在重启服务..."
    do_stop
    sleep 1
    do_start
}

do_status() {
    echo -e "${BLUE}=== 天翼云保活服务状态 ===${NC}"
    echo ""
    
    if check_running; then
        PID=$(get_pid)
        echo -e "状态: ${GREEN}运行中${NC}"
        echo "PID: $PID"
        
        if [ -f "$LOG_FILE" ]; then
            LOG_SIZE=$(du -h "$LOG_FILE" | cut -f1)
            echo "日志大小: $LOG_SIZE"
        fi
    else
        echo -e "状态: ${RED}未运行${NC}"
    fi
    
    echo ""
    echo "配置目录: $CONFIG_DIR"
    echo "配置文件: $([ -f "$CONFIG_FILE" ] && echo "已配置" || echo "未配置")"
    echo "日志文件: $LOG_FILE"
}

do_logs() {
    if [ ! -f "$LOG_FILE" ]; then
        log_warn "日志文件不存在"
        return 1
    fi
    
    if [ "$1" = "-f" ]; then
        log_info "实时查看日志 (Ctrl+C 退出)..."
        tail -f "$LOG_FILE"
    else
        echo -e "${BLUE}=== 最近日志 ===${NC}"
        tail -n 50 "$LOG_FILE"
    fi
}

do_uninstall() {
    log_warn "即将卸载天翼云保活服务..."
    
    if check_running; then
        do_stop
    fi
    
    read -p "是否删除配置文件？(y/n): " confirm
    if [ "$confirm" = "y" ] || [ "$confirm" = "Y" ]; then
        rm -rf "$CONFIG_DIR"
        log_info "配置文件已删除"
    fi
    
    sudo rm -f "/usr/local/bin/ctyun"
    log_info "卸载完成"
}

main() {
    if [ ! -d "$CONFIG_DIR" ]; then
        mkdir -p "$CONFIG_DIR"
    fi
    
    case "${1:-help}" in
        config)
            do_config
            ;;
        start)
            do_start
            ;;
        stop)
            do_stop
            ;;
        restart)
            do_restart
            ;;
        status)
            do_status
            ;;
        logs)
            do_logs "$2"
            ;;
        uninstall)
            do_uninstall
            ;;
        help|--help|-h)
            show_help
            ;;
        *)
            log_error "未知命令: $1"
            show_help
            exit 1
            ;;
    esac
}

main "$@"
